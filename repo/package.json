{
  "name": "carereserve-api",
  "version": "0.1.0",
  "private": true,
  "description": "CareReserve modular monolith API skeleton",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test:unit": "node ./node_modules/jest/bin/jest.js --config jest.unit.config.js --runInBand",
    "test:integration": "node ./node_modules/jest/bin/jest.js --config jest.integration.config.js --runInBand",
    "test:coverage": "node ./node_modules/jest/bin/jest.js --config jest.unit.config.js --runInBand --coverage",
    "test:coverage:unit": "node ./node_modules/jest/bin/jest.js --config jest.unit.config.js --runInBand --coverage",
    "test:coverage:integration": "node ./node_modules/jest/bin/jest.js --config jest.integration.config.js --runInBand --coverage --coverageDirectory=coverage/integration",
    "test:api": "bash tests/API_tests/run_api_tests.sh",
    "test:perf": "node scripts/perf-check.js",
    "test:api:ps": "powershell -ExecutionPolicy Bypass -File run_tests.ps1 -ApiOnly",
    "test": "bash run_tests.sh",
    "audit:retention": "ts-node src/scripts/run-audit-retention.ts",
    "typeorm": "typeorm-ts-node-commonjs -d src/database/data-source.ts",
    "typeorm:prod": "typeorm -d dist/database/data-source.prod.js",
    "migration:generate": "npm run typeorm -- migration:generate src/database/migrations/AutoMigration",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "migration:run:prod": "npm run typeorm:prod -- migration:run"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.2",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.2",
    "@nestjs/platform-express": "^10.4.2",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/throttler": "^6.2.1",
    "helmet": "^8.0.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.2",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.8.7",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.6.3"
  }
}
