NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=carereserve
DB_PASSWORD=carereserve
DB_NAME=carereserve

# Required: strong production-grade secret (min 32 chars, high entropy, not default text)
JWT_SECRET=REPLACE_WITH_STRONG_32_PLUS_CHAR_SECRET
JWT_EXPIRES_IN_SECONDS=3600
# Optional: absolute session lifetime for refresh-token rotation (seconds). Default 604800 (7 days).
# JWT_REFRESH_EXPIRES_IN_SECONDS=604800
# Login lockout duration after failed attempts (minutes). Default 15. Shorten only in local/dev experiments — API tests do not wait real time.
# AUTH_LOGIN_LOCK_MINUTES=15
RESET_TOKEN_EXPIRES_IN_MINUTES=15
UPLOAD_DIR=/uploads
SENSITIVE_WORDS=
# Required: strong production-grade encryption key (min 32 chars, high entropy, not default text)
IDENTITY_DOC_ENCRYPTION_KEY=REPLACE_WITH_STRONG_32_PLUS_CHAR_KEY
BUSINESS_TZ=UTC
BUSINESS_DAY_START_HOUR=9
BUSINESS_DAY_END_HOUR=17
BUSINESS_WORK_DAYS=1,2,3,4,5
# Optional comma-separated YYYY-MM-DD dates (business calendar in BUSINESS_TZ) treated as non-working days for SLA
# BUSINESS_HOLIDAYS=2026-12-25,2026-01-01
# Set to true to use wall-clock hours for workflow SLA deadlines (default: business hours)
WORKFLOW_SLA_USE_CLOCK_HOURS=false
# Hours before deadline_at to send in-app SLA reminder (wall-clock window; deadline uses business hours unless clock SLA is on)
WORKFLOW_REMINDER_LEAD_HOURS=2
AUDIT_RETENTION_YEARS=7
